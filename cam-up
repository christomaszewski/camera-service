#!/usr/bin/env bash
# cam-up [--dev|--jp6|--jp7] <sensor-config.yaml> [docker-compose subcommand + args...]
#
# Bring up ONE GigE sensor's stack from ONE config (the single source of truth). Reads the
# config, turns its enabled `isolation: container` plugins into compose profiles, parameterizes
# the stack (project name, shared shm volume, per-plugin env), and runs `docker compose`.
# It SELECTS + PARAMETERIZES — it never generates a compose file.
#
#   cam-up config/sensors/cam_a.yaml             # prod: auto-detects the JP6/JP7 host, host net (foreground up)
#   cam-up --dev config/sensors/cam_a.yaml       # dev (no Jetson): cam-dev core, bridge net
#   cam-up --jp7 config/sensors/cam_a.yaml up -d # force JetPack 7 (Orin): runc + CDI NVENC device
#   cam-up --jp6 config/sensors/cam_a.yaml up -d # force JetPack 6: l4t base + nvidia runtime (CSV)
#   cam-up --dev config/sensors/cam_a.yaml up -d # detached
#   cam-up --zenohd config/sensors/cam_a.yaml up -d # also start the shared host zenoh router (ros2, standalone)
#   cam-up --jp6 --roscore config/sensors/cam_a.yaml up -d # ros1-bridge: jp6-class core + shared roscore
#   cam-up --dev config/sensors/cam_a.yaml down  # tear the sensor down
#   cam-up --dev config/sensors/cam_a.yaml config  # just render the merged compose
#   cam-up /any/host/path/cam_front.yaml up -d      # config from an arbitrary path (e.g. via `rig`)
#
# Multiple cameras = run it per config; each is its own compose project + shm volume + ports.
# Another stack reads a sensor's frames by mounting its volume (cam_<name>_sock) + --ipc=host.
#
# Platform (JP6/JP7) is auto-detected per host from /etc/nv_tegra_release; override with --jp6/--jp7
# or CAM_PLATFORM={jp6,jp7}. It's a HOST fact (same for every sensor on the box), so rig pins it
# per host (env), never per sensor.
set -euo pipefail
REPO="$(cd "$(dirname "$0")" && pwd)"
PYTHON="${CAM_PYTHON:-python3}"

DEV=0; ZENOHD=0; ROSCORE=0; PLATFORM="${CAM_PLATFORM:-auto}"   # auto -> detect JP6/JP7; jp6|jp7 to pin
while :; do case "${1:-}" in
  --dev) DEV=1; shift;;
  --jp7) PLATFORM=jp7; shift;;   # force JetPack 7 (Orin): runc + the CDI NVENC device overlay
  --jp6) PLATFORM=jp6; shift;;   # force JetPack 6: l4t base + nvidia runtime (CSV mounts)
  --zenohd) ZENOHD=1; shift;;    # bring up the shared host zenoh router first (standalone; rig owns it in prod)
  --roscore) ROSCORE=1; shift;;  # bring up the shared host roscore first (ROS 1 / ros1-bridge; rig owns it in prod)
  *) break;;
esac; done
CONFIG="${1:?usage: cam-up [--dev|--jp6|--jp7] <sensor-config.yaml> [compose args...]}"; shift || true
# Accept the config as given (abs / cwd-relative -- e.g. a rig-supplied vehicle path), or fall back to
# the documented short form resolved against the in-repo config dir (config/sensors/foo.yaml lives
# under core-driver/, which isn't the repo root) so `cam-up config/sensors/foo.yaml` works anywhere.
if [ ! -f "$CONFIG" ] && [ -f "$REPO/core-driver/$CONFIG" ]; then
  CONFIG="$REPO/core-driver/$CONFIG"
fi
[ -f "$CONFIG" ] || { echo "cam-up: config not found: $CONFIG" >&2; exit 1; }
CONFIG_ABS="$(cd "$(dirname "$CONFIG")" && pwd)/$(basename "$CONFIG")"
# Tolerate a missing sensors dir: a VENDORED launch surface (rig deploy) doesn't ship it, so this
# cd would die under `set -e`. Empty SENSORS_DIR => every config is treated as external (correct --
# rig always supplies the config from outside the repo), so the external-config overlay kicks in.
SENSORS_DIR="$(cd "$REPO/core-driver/config/sensors" 2>/dev/null && pwd || true)"

# The docker compose subcommand (default `up`). `config` -- which `rig bake` runs to RENDER the merged
# compose for the target -- must be HOST-INDEPENDENT: a pure function of (this config + rig's env) with NO
# probing/mutating of the bake box (no JetPack detection, no device-existence check, no `docker volume
# create`). So the captured compose is correct for the TARGET vehicle, not the dev box it was baked on.
VERB="${1:-up}"

if ! docker compose version >/dev/null 2>&1; then
  echo "cam-up: needs the Docker Compose v2 plugin ('docker compose'); 'include' needs >= 2.20" >&2
  exit 1
fi

# config -> env (selection + parameterization). Values are simple tokens (no spaces).
eval "$("$PYTHON" "$REPO/tools/sensor_env.py" "$CONFIG" | sed 's/^/export /')"
export CAM_CONFIG="config/sensors/$(basename "$CONFIG")"   # in-container path (config dir is mounted)
export CAM_NETWORK="${CAM_NETWORK:-host}"
[ "$DEV" = 1 ] && export CAM_NETWORK=bridge
# ROS 2 middleware: rmw_zenoh_cpp is the default across the stack (discovers via a shared host
# `rmw_zenohd` router; see --zenohd / tools/zenohd.sh). FastDDS stays selectable via RMW_IMPLEMENTATION.
export RMW_IMPLEMENTATION="${RMW_IMPLEMENTATION:-rmw_zenoh_cpp}"

# shm transport = a stable EXTERNAL volume, so sibling and other-stack containers can attach. Skip it for
# `config`: a pure render must not mutate (or even reach) the daemon -- `docker compose config` doesn't
# need the volume to exist, and `rig bake` may render on a box with no running daemon.
[ "$VERB" = config ] || docker volume create "$CAM_SOCK_VOLUME" >/dev/null

# Resolve auto -> the target platform (drives BOTH the image tag cam-core:<platform> AND the runtime
# overlay docker-compose.<platform>.yml). rig's DECLARED target wins over host detection: RIG_IMAGE_TAG
# (= vehicle.yaml images.tag, e.g. jp7) is authoritative because rig bakes on a dev box that often isn't a
# Jetson -- host-detecting THERE picks the wrong platform (jp6 on a Mac), pinning the wrong image tag AND
# omitting the target's NVENC/CDI overlay. Standalone (RIG_IMAGE_TAG unset): fall back to the L4T release
# line (R36 = JP6; R38+ = JP7). Skipped under --dev; a missing release file -> jp6 (conservative).
if [ "$DEV" = 0 ] && [ "$PLATFORM" = auto ]; then
  if [ -n "${RIG_IMAGE_TAG:-}" ]; then
    PLATFORM="$RIG_IMAGE_TAG"
  elif [ "$VERB" != config ]; then
    # Live `up` on the target host with no rig tag: fall back to the L4T release line. NEVER for `config`
    # -- a bake renders on a dev box (often not a Jetson), where host-probing picks the wrong platform;
    # `config` stays a pure function of (config + rig env) and takes the conservative jp6 default below.
    REL=""; [ -r /etc/nv_tegra_release ] && REL="$(sed -n 's/^# R\([0-9][0-9]*\).*/\1/p' /etc/nv_tegra_release)"
    if [ "${REL:-0}" -ge 38 ] 2>/dev/null; then PLATFORM=jp7; else PLATFORM=jp6; fi
  fi
fi
# Dev / unresolved -> the conservative shm+header transport. Export the resolved platform so the
# ros2-bridge picks the matching consumer (CamUnixfdBridge on jp7, CamHeaderBridge otherwise) -- the
# core selects its transport the same way (unixfd exactly when GStreamer >= 1.24 / jp7).
[ "$PLATFORM" = auto ] && PLATFORM=jp6
export CAM_PLATFORM="$PLATFORM"

FILES=(-f "$REPO/docker-compose.yml")
[ "$DEV" = 1 ] && FILES+=(-f "$REPO/docker-compose.dev.yml")
# One host fact drives both axes. JP7: the runc + CDI-device overlay, and default the build base to
# 24.04. JP6: the base compose's nvidia runtime + l4t base (its existing defaults). The image TAG
# stays ${CAM_CORE_IMAGE:-cam-core}; set CAM_CORE_IMAGE to a registry tag for pull-based deploys.
if [ "$DEV" = 0 ] && [ "$PLATFORM" = jp7 ]; then
  FILES+=(-f "$REPO/docker-compose.jp7.yml")
  export CAM_CORE_BASE="${CAM_CORE_BASE:-ubuntu:24.04}"
fi
# USB source: map the v4l2 device into the core container (gige/rtsp need no device). sensor_env exports
# CAM_DEVICE (the config's usb.device) for a REAL non-fake usb source. ALWAYS render the overlay from the
# config -- device EXISTENCE is a RUNTIME check on the vehicle (Docker errors at `up` if the node is
# absent), NOT a bake-time host probe -- so `config` on a camera-less dev box still emits the right mapping.
# The overlay self-maps the configured path; Docker resolves the host symlink + mknods it at `up` (no
# host-side `readlink`, which would be a probe and would be wrong on the bake box).
if [ -n "${CAM_DEVICE:-}" ]; then
  export CAM_DEVICE
  FILES+=(-f "$REPO/docker-compose.usb.yml")
fi
# Registry deploy (no per-vehicle build): CAM_REGISTRY points every image at <registry>/<name>:<tag>,
# tag following the detected platform (matches tools/build-images.sh) so one var pulls the whole stack.
# Per-image vars still override individually. Then `cam-up <cfg> pull` + `up -d` runs the pulled images.
# rig injects RIG_IMAGE_REGISTRY fleet-wide; honor it here so cam's PLATFORM-TAGGED refs (cam-core:jp7)
# come out right -- the raw ${RIG_IMAGE_REGISTRY}/cam-core prefix in the composes would resolve :latest.
CAM_REGISTRY="${CAM_REGISTRY:-${RIG_IMAGE_REGISTRY:-}}"
if [ "$DEV" = 0 ] && [ -n "${CAM_REGISTRY:-}" ]; then
  IMG_TAG="${CAM_IMAGE_TAG:-$PLATFORM}"
  export CAM_CORE_IMAGE="${CAM_CORE_IMAGE:-$CAM_REGISTRY/cam-core:$IMG_TAG}"
  export CAM_ROS2_IMAGE="${CAM_ROS2_IMAGE:-$CAM_REGISTRY/ros2-bridge:$IMG_TAG}"
  export CAM_ROS1_IMAGE="${CAM_ROS1_IMAGE:-$CAM_REGISTRY/ros1-bridge:$IMG_TAG}"   # Noetic; ros1-bridge is jp6-class
  export CAM_WEBRTC_IMAGE="${CAM_WEBRTC_IMAGE:-$CAM_REGISTRY/webrtc-bridge:$IMG_TAG}"
fi
# --zenohd: ensure the single shared host zenoh router is up before the stack (standalone convenience;
# rig runs it per host in production). Idempotent + one-per-host; reuses the resolved ros2-bridge image.
if [ "$ZENOHD" = 1 ]; then CAM_ROS2_IMAGE="${CAM_ROS2_IMAGE:-ros2-bridge}" "$REPO/tools/zenohd.sh" up; fi
# --roscore: same, for the ROS 1 master (ros1-bridge consumers; mirrors --zenohd). One per host, idempotent.
if [ "$ROSCORE" = 1 ]; then CAM_ROS1_IMAGE="${CAM_ROS1_IMAGE:-ros1-bridge}" "$REPO/tools/roscore.sh" up; fi
# Config from an arbitrary host path (e.g. a vehicle-level config managed by `rig`): bind-mount
# that single file into the container so the core/supervisor loads it. In-repo configs (under
# core-driver/config/sensors/) already live in the mounted config dir, so no overlay is needed.
if [ "$(dirname "$CONFIG_ABS")" != "$SENSORS_DIR" ]; then
  export CAM_CONFIG_HOST="$CONFIG_ABS"
  export CAM_CONFIG="/run/cam-sensor.yaml"   # mount target OUTSIDE the read-only /app/config mount
  FILES+=(-f "$REPO/docker-compose.external-config.yml")
fi

ARGS=("$@"); [ ${#ARGS[@]} -eq 0 ] && ARGS=(up)
PLAT_LABEL="$([ "$DEV" = 1 ] && echo dev || echo "$PLATFORM")"
echo "cam-up: project=$COMPOSE_PROJECT_NAME platform=$PLAT_LABEL${CAM_REGISTRY:+ registry=$CAM_REGISTRY} profiles=[${COMPOSE_PROFILES:-<none>}] sock=$CAM_SOCK_VOLUME net=$CAM_NETWORK rmw=$RMW_IMPLEMENTATION config=$CAM_CONFIG${CAM_CONFIG_HOST:+ (external: $CAM_CONFIG_HOST)}" >&2
exec docker compose "${FILES[@]}" "${ARGS[@]}"
